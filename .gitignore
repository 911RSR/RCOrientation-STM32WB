# ignore build outputs generated by STM32CubeIDE / Make
/Debug/
/Release/
/build/

# STM32CubeIDE/Eclipse local workspace metadata. Regenerate/import locally from the .ioc file.
.project
.cproject
.mxproject
.settings/
*.launch

# local linker-script experiments kept out of the reproducible project set
*.generated-bad.ld
*.working.ld

# For PCBs designed using KiCad: https://www.kicad.org/
