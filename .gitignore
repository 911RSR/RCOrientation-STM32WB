# Temporary files
*.000
*.bak
*.bck
*.kicad_pcb-bak
*.kicad_sch-bak
*-backups
*.kicad_prl
*.sch-bak
*~
_autosave-*
*.tmp
*-save.pro
*-save.kicad_pcb
fp-info-cache

# Netlist files (exported from Eeschema)
*.net

# Autorouter files
*.dsn
*.ses

# Exported BOM files
*.xml
*.csv

# Prerequisites
*.d

# Object files
*.o
*.ko
*.obj
*.elf

